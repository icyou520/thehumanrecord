{{ $all := slice }}
{{ range .Site.RegularPages }}
{{ $record := dict
  "id" .Params.id
  "title" .Title
  "type" .Params.type
  "summary" .Params.summary
  "url" .Permalink
  "traditions" .Params.traditions
  "tags" .Params.tags
  "created" .Params.created
  "updated" .Params.updated
  "version" .Params.version
}}
{{ $all = $all | append $record }}
{{ end }}
{
  "name": "{{ .Site.Title }}",
  "description": "{{ .Site.Params.description }}",
  "license": "{{ .Site.Params.license }}",
  "url": "{{ .Site.BaseURL }}",
  "count": {{ len .Site.RegularPages }},
  "records": {{ $all | jsonify (dict "indent" "  ") }}
}
